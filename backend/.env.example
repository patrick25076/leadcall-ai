# ─── Core AI ────────────────────────────────────────────────────────────────
# Google Generative AI (Gemini — used by ADK agents)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_GENAI_USE_VERTEXAI=false

# ─── Lead Discovery ─────────────────────────────────────────────────────────
# Google Maps Places API (separate key with Places API enabled)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Brave Search API
BRAVE_API_KEY=your-brave-api-key

# Firecrawl (multi-page website crawling, optional — falls back to BS4)
FIRECRAWL_API_KEY=your-firecrawl-api-key

# ─── Voice & Calling ────────────────────────────────────────────────────────
# ElevenLabs Conversational AI
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Phone number ID from ElevenLabs (import Twilio number into ElevenLabs first)
# Go to: ElevenLabs Dashboard > Conversational AI > Phone Numbers > Import
ELEVENLABS_PHONE_NUMBER_ID=your-elevenlabs-phone-number-id

# Twilio (fallback for BYO Twilio — only needed if not using ElevenLabs direct calling)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Email Outreach ─────────────────────────────────────────────────────────
# Resend (platform emails only — welcome, notifications)
RESEND_API_KEY=your-resend-api-key

# Google OAuth (for "Connect Gmail" — users send from their own account)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/gmail/callback

# ─── Database & Auth ────────────────────────────────────────────────────────
# Supabase (PostgreSQL + Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── Observability ──────────────────────────────────────────────────────────
# Orq AI (tracing & monitoring)
ORQ_API_KEY=your-orq-api-key

# ─── Infrastructure ─────────────────────────────────────────────────────────
# Webhook base URL (for Twilio callbacks — set to your public URL)
WEBHOOK_BASE_URL=https://your-backend-url.com

# CORS: comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app

# Admin access (comma-separated Supabase user UUIDs)
ADMIN_USER_IDS=your-supabase-user-uuid

# Test mode: override call destination (REMOVE IN PRODUCTION)
# TEST_PHONE_OVERRIDE=+40700000000

# ─── MCP Server Tokens (for Claude Code — NOT used by the app) ─────────────
# These are used by .mcp.json for Claude Code's MCP integrations.
# Set them as system environment variables or in a shell profile, NOT here.
#
# RENDER_API_KEY=rnd_xxxx
