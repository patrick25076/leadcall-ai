# Google Generative AI (Gemini — used by ADK agents)
GOOGLE_API_KEY=your-google-api-key
GOOGLE_GENAI_USE_VERTEXAI=false

# Google Maps Places API (separate key with Places API enabled)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ElevenLabs Conversational AI
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Twilio (outbound calling)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Orq AI (tracing & observability)
ORQ_API_KEY=your-orq-api-key

# Brave Search API (lead discovery)
BRAVE_API_KEY=your-brave-api-key

# Firecrawl (multi-page website crawling, optional — falls back to BS4)
FIRECRAWL_API_KEY=your-firecrawl-api-key

# Webhook base URL (for Twilio callbacks — set to your public URL or ngrok)
WEBHOOK_BASE_URL=https://your-ngrok-or-railway-url
